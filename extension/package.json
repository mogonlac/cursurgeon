{
  "name": "cursurgeon",
  "displayName": "Cursurgeon",
  "description": "Side pane with live project preview, screenshot-to-inline-prompt for Cursor chat.",
  "version": "0.4.0",
  "publisher": "mogonlac",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/mogonlac/cursurgeon.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onView:cursurgeon.preview",
    "onCommand:cursurgeon.openPanel",
    "onCommand:cursurgeon.openSimpleBrowser",
    "onCommand:cursurgeon.focusPreview"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Cursurgeon",
      "properties": {
        "cursurgeon.previewUrl": {
          "type": "string",
          "default": "http://localhost:5173",
          "description": "Default URL for the live preview iframe (e.g. Vite dev server)."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cursurgeon",
          "title": "Cursurgeon",
          "icon": "resources/icon.png"
        }
      ]
    },
    "views": {
      "cursurgeon": [
        {
          "type": "webview",
          "id": "cursurgeon.preview",
          "name": "Cursurgeon",
          "contextualTitle": "Cursurgeon"
        }
      ]
    },
    "commands": [
      {
        "command": "cursurgeon.focusPreview",
        "title": "Cursurgeon: Focus side pane",
        "category": "Cursurgeon"
      },
      {
        "command": "cursurgeon.openPanel",
        "title": "Cursurgeon: Open beside editor",
        "category": "Cursurgeon"
      },
      {
        "command": "cursurgeon.openSimpleBrowser",
        "title": "Cursurgeon: Open preview URL in Simple Browser",
        "category": "Cursurgeon"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "typescript": "~5.6.2"
  }
}
